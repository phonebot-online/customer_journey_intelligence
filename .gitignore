# macOS
.DS_Store
**/.DS_Store

# DuckDB runtime files (regenerated from CSVs on each `npm start`)
app/data/*.db
app/data/*.db.wal
app/data/*.db.tmp
app/data/*.db-journal

# Node
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Build output (we DO commit app/dist/ for the deployed bundle)
# (intentionally not ignoring app/dist/ — keep the built JS/CSS in git)

# Editor / IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Local env / secrets
.env
.env.local
.env.*.local

# Logs
*.log
/tmp/

# Diagnostic outputs (regenerated from running scripts)
outputs/
scripts/gclid_trace/outputs/

# Per-tool node_modules under scripts/
scripts/*/node_modules/
scripts/*/package-lock.json
