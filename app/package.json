{
  "name": "phonebot-marketing-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch api/boot.ts",
    "build": "tsc && vite build",
    "check": "tsc --noEmit",
    "start": "tsx api/boot.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@tanstack/react-query": "^5.74.4",
    "@trpc/client": "^11.13.0",
    "@trpc/react-query": "^11.13.0",
    "@trpc/server": "^11.13.0",
    "@types/serve-static": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "duckdb": "^1.2.2",
    "hono": "^4.7.7",
    "lucide-react": "^0.488.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.1",
    "recharts": "^2.15.3",
    "serve-static": "^2.2.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^3.4.19",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
